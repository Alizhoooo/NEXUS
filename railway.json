{
  "$schema": "https://railway.app/schema.json",
  "name": "nexus",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "build": {
        "dockerfilePath": "Dockerfile"
      }
    }
  }
}