FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Install Prisma and generate client
RUN npm install -D prisma @prisma/client
RUN npx prisma generate

# Copy application files
COPY . .

# Expose ports
EXPOSE 3000 3001

# Start development server
CMD ["npm", "run", "dev"]