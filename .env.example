# ==============================================
# NEXUS Environment Configuration
# ==============================================

# Backend
PORT=3001
NODE_ENV=development

# JWT Secret - REQUIRED - минимум 32 символа
# Генерируйте надежный ключ: openssl rand -base64 32
NEXUS_TOKEN_SECRET=change-this-to-a-secure-random-string-min-32-chars

# CSRF Secret - автоматически генерируется если не указан
# CSRF_SECRET=

# Database - PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus?schema=public

# Redis - для кэширования и сессий (опционально)
REDIS_URL=redis://localhost:6379

# CORS - разрешенные frontend origins (через запятую для нескольких)
CORS_ORIGIN=http://localhost:3000

# Frontend API URL - оставьте пустым для локального Vite proxy; укажите backend URL для Vercel/Render frontend
VITE_API_BASE_URL=

# Gemini AI Integration (optional)
# Получить ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Logging
LOG_LEVEL=info
