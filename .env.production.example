# ==============================================
# NEXUS Production Environment (Railway)
# ==============================================

# Backend
PORT=3001
NODE_ENV=production

# JWT Secret - генерируй: openssl rand -base64 32
NEXUS_TOKEN_SECRET=

# Database - заполнится автоматически через Railway
DATABASE_URL=

# Redis - заполнится автоматически через Railway
REDIS_URL=

# CORS - frontend domains на Railway/Render/Vercel (через запятую для нескольких)
CORS_ORIGIN=

# Frontend API URL - backend URL для Vercel/Render frontend, например https://nexus-3-4vzk.onrender.com
VITE_API_BASE_URL=

# Gemini AI (optional)
GEMINI_API_KEY=
