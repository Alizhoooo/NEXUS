# ==============================================
# NEXUS Production Environment (Railway)
# ==============================================

# Backend
PORT=3001
NODE_ENV=production

# JWT Secret - генерируй: openssl rand -base64 32
NEXUS_TOKEN_SECRET=

# Database - заполнится автоматически через Railway
DATABASE_URL=

# Redis - заполнится автоматически через Railway
REDIS_URL=

# CORS - твой domain на Railway
CORS_ORIGIN=

# Gemini AI (optional)
GEMINI_API_KEY=